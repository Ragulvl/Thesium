{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"VITE,API\" -c \"cyan,magenta\" \"npm run dev:frontend --silent\" \"npm run dev:api --silent\"",
    "dev:frontend": "vite --logLevel silent --clearScreen false",
    "dev:api": "nodemon --quiet --watch server --ext ts --exec ts-node server/index.ts",
    "build": "npx prisma generate && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@react-oauth/google": "^0.13.4",
    "@supabase/supabase-js": "^2.57.4",
    "chalk": "^4.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.344.0",
    "openai": "^6.29.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pino": "^7.0.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.9.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.35",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
